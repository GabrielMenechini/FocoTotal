{
  "name": "focototal-backend",
  "version": "1.0.0",
  "description": "Sistema de Gestão para Ótica - Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
